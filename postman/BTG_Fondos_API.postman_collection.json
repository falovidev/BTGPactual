          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Cancelación exitosa', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.type).to.eql('CANCELLATION');",
                  "    pm.expect(json.fundName).to.eql('FPV_BTG_PACTUAL_RECAUDADORA');",
                  "    pm.expect(json.amount).to.eql(75000);",
                  "});"
